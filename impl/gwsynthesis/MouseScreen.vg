output clkn;
output bp;
output bn;
output gp;
output gn;
output rp;
output rn;
output n466_3;
wire n690_5;
wire [2:0] tmds_bit;
wire [9:0] TMDS_r;
wire [9:0] TMDS_g;
wire [9:0] TMDS_b;
wire VCC;
wire GND;
  ELVDS_OBUF \elvds[3]  (
    .O(clkp),
    .OB(clkn),
    .I(clk_p) 
);
  ELVDS_OBUF \elvds[2]  (
    .O(bp),
    .OB(bn),
    .I(tmds_bit[2]) 
);
  ELVDS_OBUF \elvds[1]  (
    .O(gp),
    .OB(gn),
    .I(tmds_bit[1]) 
);
  ELVDS_OBUF \elvds[0]  (
    .O(rp),
    .OB(rn),
    .I(tmds_bit[0]) 
);
  OSER10 \tmds_serdes[2]  (
    .Q(tmds_bit[2]),
    .D0(TMDS_b[0]),
    .D1(TMDS_b[1]),
    .D2(TMDS_b[2]),
    .D3(TMDS_b[3]),
    .D4(TMDS_b[4]),
    .D5(TMDS_b[5]),
    .D6(TMDS_b[6]),
    .D7(TMDS_b[7]),
    .D8(TMDS_b[8]),
    .D9(TMDS_b[9]),
    .PCLK(clk_p),
    .FCLK(clk_TMDS),
    .RESET(button_s1_d) 
);
  OSER10 \tmds_serdes[1]  (
    .Q(tmds_bit[1]),
    .D0(TMDS_g[0]),
    .D1(TMDS_g[1]),
    .D2(TMDS_g[2]),
    .D3(TMDS_g[3]),
    .D4(TMDS_g[4]),
    .D5(TMDS_g[5]),
    .D6(TMDS_g[6]),
    .D7(TMDS_g[7]),
    .D8(TMDS_g[8]),
    .D9(TMDS_g[9]),
    .PCLK(clk_p),
    .FCLK(clk_TMDS),
    .RESET(button_s1_d) 
);
  OSER10 \tmds_serdes[0]  (
    .Q(tmds_bit[0]),
    .D0(TMDS_r[0]),
    .D1(TMDS_r[1]),
    .D2(TMDS_r[2]),
    .D3(TMDS_r[3]),
    .D4(TMDS_r[4]),
    .D5(TMDS_r[5]),
    .D6(TMDS_r[6]),
    .D7(TMDS_r[7]),
    .D8(TMDS_r[8]),
    .D9(TMDS_r[9]),
    .PCLK(clk_p),
    .FCLK(clk_TMDS),
    .RESET(button_s1_d) 
);
  svo_tmds encode_R (
    .clk_p(clk_p),
    .button_s1_d(button_s1_d),
    .red(red[7:0]),
    .counterY(counterY[10:4]),
    .counterX(counterX[10:8]),
    .n466_3(n466_3),
    .n690_5(n690_5),
    .TMDS_r(TMDS_r[9:0])
);
  svo_tmds_0 encode_G (
    .clk_p(clk_p),
    .n466_3(n466_3),
    .button_s1_d(button_s1_d),
    .n690_5(n690_5),
    .green(green[7:0]),
    .TMDS_g(TMDS_g[9:0])
);
  svo_tmds_1 encode_B (
    .clk_p(clk_p),
    .n466_3(n466_3),
    .button_s1_d(button_s1_d),
    .n690_5(n690_5),
    .done_d(done_d),
    .n263_11(n263_11),
    .blue(blue[7:0]),
    .counterX(counterX[10:1]),
    .TMDS_b(TMDS_b[9:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* hdmi */
