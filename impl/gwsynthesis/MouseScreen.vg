module hdmi (
  clk_p,
  clk_TMDS,
  button_s1_d,
  done_d,
  n263_11,
  red,
  counterY,
  counterX,
  green,
  blue,
  clkp,
  clkn,
  bp,
  bn,
  gp,
  gn,
  rp,
  rn,
  n466_3
)
;
input clk_p;
input clk_TMDS;
input button_s1_d;
input done_d;
input n263_11;
input [7:0] red;
input [10:4] counterY;
input [10:1] counterX;
input [7:0] green;
input [7:0] blue;
